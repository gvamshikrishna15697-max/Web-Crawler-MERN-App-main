{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://web-crawler-mern-app-main.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://web-crawler-mern-app-main.onrender.com/health"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
